<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B1018">

    <ImageView
        android:id="@+id/w_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/scene_clear_day"
        android:contentDescription="@null" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical">
            <TextView
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="Brämhult" android:textColor="@color/ink" android:textStyle="bold"
                android:textSize="14sp" android:shadowColor="#e6000000" android:shadowRadius="3.5" android:shadowDx="0" android:shadowDy="0"/>
            <TextView android:id="@+id/w_when"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="—" android:textColor="@color/ink2" android:textSize="11sp"
                android:shadowColor="#d9000000" android:shadowRadius="3.5"/>
        </LinearLayout>

        <!-- Hero: stor temperatur (över scenen) + sol -->
        <LinearLayout
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:paddingTop="2dp" android:paddingBottom="2dp">

            <LinearLayout android:id="@+id/c_temp"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:orientation="vertical">
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:baselineAligned="true">
                    <TextView android:id="@+id/w_temp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="–" android:textColor="@color/ink" android:textStyle="bold"
                        android:textSize="44sp" android:includeFontPadding="false"
                        android:shadowColor="#e6000000" android:shadowRadius="3.5" android:shadowDx="0" android:shadowDy="0"/>
                    <TextView
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="°C" android:textColor="@color/ink2" android:textSize="16sp"
                        android:paddingStart="3dp"
                        android:shadowColor="#cc000000" android:shadowRadius="3"/>
                </LinearLayout>
                <TextView android:id="@+id/w_sub"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="" android:textColor="@color/ink2" android:textSize="11sp"
                    android:shadowColor="#d9000000" android:shadowRadius="3.5"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:orientation="vertical" android:gravity="end">
                <TextView android:id="@+id/w_icon"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="☀️" android:textSize="26sp" android:gravity="end"/>
                <TextView android:id="@+id/w_sun"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="" android:textColor="@color/ink2" android:textSize="11sp"
                    android:gravity="end" android:paddingTop="2dp"
                    android:shadowColor="#cc000000" android:shadowRadius="3"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Rad 1 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:weightSum="4" android:paddingTop="8dp">
            <LinearLayout android:id="@+id/c_wind" style="@style/WCell"><TextView android:id="@+id/w_wind" style="@style/WVal"/><TextView style="@style/WLab" android:text="Vind m/s"/></LinearLayout>
            <LinearLayout android:id="@+id/c_wnow" style="@style/WCell"><TextView android:id="@+id/w_wnow" style="@style/WVal"/><TextView style="@style/WLab" android:text="Vind nu"/></LinearLayout>
            <LinearLayout android:id="@+id/c_rain" style="@style/WCell"><TextView android:id="@+id/w_rain" style="@style/WVal"/><TextView style="@style/WLab" android:text="Regn mm"/></LinearLayout>
            <LinearLayout style="@style/WCell"><TextView android:id="@+id/w_hum" style="@style/WVal"/><TextView style="@style/WLab" android:text="Fukt %"/></LinearLayout>
        </LinearLayout>

        <!-- Rad 2 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:weightSum="4" android:paddingTop="8dp">
            <LinearLayout android:id="@+id/c_press" style="@style/WCell"><TextView android:id="@+id/w_press" style="@style/WVal"/><TextView style="@style/WLab" android:text="Tryck hPa"/></LinearLayout>
            <LinearLayout android:id="@+id/c_uv" style="@style/WCell"><TextView android:id="@+id/w_uv" style="@style/WVal"/><TextView style="@style/WLab" android:text="UV"/></LinearLayout>
            <LinearLayout android:id="@+id/c_lux" style="@style/WCell"><TextView android:id="@+id/w_lux" style="@style/WVal"/><TextView style="@style/WLab" android:text="Ljus"/></LinearLayout>
            <LinearLayout style="@style/WCell"><TextView android:id="@+id/w_wdir" style="@style/WVal"/><TextView style="@style/WLab" android:text="Riktn."/></LinearLayout>
        </LinearLayout>

        <!-- Pool (döljs om anläggningen inte rapporterar data) -->
        <LinearLayout android:id="@+id/c_pool"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:weightSum="4" android:paddingTop="8dp"
            android:visibility="gone">
            <LinearLayout style="@style/WCell"><TextView android:id="@+id/w_pool_temp" style="@style/WVal"/><TextView style="@style/WLab" android:text="Pool °C"/></LinearLayout>
            <LinearLayout style="@style/WCell"><TextView android:id="@+id/w_pool_ph" style="@style/WVal"/><TextView style="@style/WLab" android:text="pH"/></LinearLayout>
            <LinearLayout style="@style/WCell"><TextView android:id="@+id/w_pool_cl" style="@style/WVal"/><TextView style="@style/WLab" android:text="Klor mg/l"/></LinearLayout>
            <LinearLayout style="@style/WCell"><TextView android:id="@+id/w_pool_flow" style="@style/WVal"/><TextView style="@style/WLab" android:text="Flöde"/></LinearLayout>
        </LinearLayout>

        <!-- Prognos (klickbara dagar) -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:weightSum="5" android:paddingTop="10dp">
            <TextView android:id="@+id/w_fc0" style="@style/WFc"/>
            <TextView android:id="@+id/w_fc1" style="@style/WFc"/>
            <TextView android:id="@+id/w_fc2" style="@style/WFc"/>
            <TextView android:id="@+id/w_fc3" style="@style/WFc"/>
            <TextView android:id="@+id/w_fc4" style="@style/WFc"/>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
