<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="WCell">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:orientation">vertical</item>
        <item name="android:gravity">center</item>
    </style>
    <style name="WVal">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/ink</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">18sp</item>
        <!-- Tät mörk halo (centrerad) ~ tunn kontur för läsbarhet mot scenen -->
        <item name="android:shadowColor">#cc000000</item>
        <item name="android:shadowRadius">2.5</item>
        <item name="android:shadowDx">0</item>
        <item name="android:shadowDy">0</item>
    </style>
    <style name="WLab">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/ink3</item>
        <item name="android:textSize">9sp</item>
        <item name="android:paddingTop">1dp</item>
        <item name="android:shadowColor">#99000000</item>
        <item name="android:shadowRadius">2</item>
        <item name="android:shadowDx">0</item>
        <item name="android:shadowDy">0</item>
    </style>
    <style name="WFc">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">@color/ink</item>
        <item name="android:textSize">11sp</item>
        <item name="android:lineSpacingExtra">1dp</item>
        <item name="android:shadowColor">#b3000000</item>
        <item name="android:shadowRadius">2</item>
        <item name="android:shadowDx">0</item>
        <item name="android:shadowDy">0</item>
    </style>
</resources>
